# ─── DataGolf API ──────────────────────────────────────────────
# Get your API key at https://datagolf.com (Scratch membership required)
DATAGOLF_API_KEY=your_datagolf_api_key_here

# ─── Notifications ─────────────────────────────────────────────
# Email alerts via Resend (https://resend.com — free tier: 3k/mo)
RESEND_API_KEY=re_your_resend_key_here
RESEND_FROM_EMAIL=Golf Edge Finder <alerts@yourdomain.com>
ALERT_EMAIL=your@email.com

# Push notifications via ntfy.sh (free, no account needed)
# 1. Install ntfy app on your phone
# 2. Subscribe to a unique topic (e.g., "golf-edges-antonio-2026")
# 3. Put that topic name here
NTFY_TOPIC=golf-edges-yourname

# ─── Security ──────────────────────────────────────────────────
# Protects the /api/notify cron endpoint from unauthorized access
# Generate: openssl rand -hex 32
CRON_SECRET=your_random_secret_here
